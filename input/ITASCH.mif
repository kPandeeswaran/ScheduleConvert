     <ElementSuffix `. '>
    > # end of ElseIf
    <ElseIf 
     <Context `Titlegrp < (Section | Rule)'>
     <ElementSuffix `. '>
    > # end of ElseIf
    <ElseIf 
     <Context `(Subsection | Clause | Subclause | Subrule)'>
     <ElementSuffix `) '>
    > # end of ElseIf
    <ElseIf 
     <Context `Explanation'>
     <ContextFormatRule 
      <If 
       <Context `* < Explanation[Change != "Omitted"]'>
       <ContextFormatRule 
        <If 
         <Context `Clause'>
         <ElementSuffix `) '>
        > # end of If
        <Else 
         <ElementSuffix `.— '>
        > # end of Else
       > # end of ContextFormatRule
      > # end of If
      <Else 
       <ElementSuffix ` '>
