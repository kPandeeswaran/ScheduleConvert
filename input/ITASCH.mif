       <FormatTag `Emphasis'>
      > # end of If
      <ElseIf 
       <Context `Clause'>
       <ElementPrefix `('>
      > # end of ElseIf
      <Else 
       <IsTextRange Yes>
       <ElementPrefix `Explanation'>
       <FormatTag `Emphasis'>
      > # end of Else
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `Proviso'>
