   > # end of Font
   <Char Tab>
   <String `From 1-4-1989 : Finance (No. 2) Act, 1998 :'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Title'>
   <ElementBegin 
    <Unique 1405463>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String ` The words in square brackets in clause (a) of rule 5 of '>
  > # end of ParaLine
  <ParaLine 
   <String `the First Schedule were substituted for the words ‘‘any expen'>
   <Char DiscHyphen>
   <String `diture or allowance’’ by the Finance '>
  > # end of ParaLine
  <ParaLine 
   <String `(No. 2) Act, 1998, with retrospective effect from April 1, 1989, to explicitly provide for disallowance '>
  > # end of ParaLine
  <ParaLine 
   <String `of provision for any tax, dividend or any reserve or any other provision prescribed by the Board and '>
  > # end of ParaLine
  <ParaLine 
   <String `debi'>
   <Char DiscHyphen>
   <String `ted to the profit and loss account.'>
   <ElementEnd `Para'>
   <ElementEnd `Notes'>
   <Marker 
    <MType 10>
    <MTypeName `Conditional Text'>
    <MText `=746230'>
    <MCurrPage `HIDDEN'>
    <Unique 1405467>
   > # end of Marker
  > # end of ParaLine
 > # end of Para
