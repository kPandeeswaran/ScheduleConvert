     <Context `Titlegrp < Section'>
     <IsTextRange Yes>
     <ContextLabel `Section'>
    > # end of ElseIf
    <ElseIf 
     <Context `Titlegrp < Rule'>
     <IsTextRange Yes>
     <ContextLabel `Rule'>
    > # end of ElseIf
    <ElseIf 
     <Context `* < Qpara'>
     <IsTextRange Yes>
    > # end of ElseIf
    <ElseIf 
     <Context `Subsection'>
     <IsTextRange Yes>
     <ContextLabel `Subsection'>
    > # end of ElseIf
    <ElseIf 
     <Context `Subrule'>
     <IsTextRange Yes>
     <ContextLabel `Subrule'>
    > # end of ElseIf
    <ElseIf 
     <Context `Clause < Explanation'>
     <IsTextRange Yes>
     <ContextLabel `ExClause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Clause < Proviso'>
     <IsTextRange Yes>
     <ContextLabel `PrClause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Clause < Rule'>
     <IsTextRange Yes>
     <ContextLabel `RlClause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Clause < Subrule'>
     <IsTextRange Yes>
     <ContextLabel `SrlClause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Clause'>
     <IsTextRange Yes>
     <ContextLabel `Clause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Subclause < Clause < Explanation'>
     <IsTextRange Yes>
     <ContextLabel `ExSubclause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Subclause < Clause < Proviso'>
     <IsTextRange Yes>
     <ContextLabel `PrSubClause'>
    > # end of ElseIf
    <ElseIf 
     <Context `Subclause < Clause < Subrule'>
     <IsTextRange Yes>
     <ContextLabel `SrlSubClause'>
