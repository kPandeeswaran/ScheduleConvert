    <Unique 1418203>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <Char Tab>
   <String `Provided that where more than one period in respect of different sources of income are included '>
  > # end of ParaLine
  <ParaLine 
   <String `in the transitional previous year under the first proviso or the third proviso to sub-section (2) of sec'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `tion 3, then the tax shall be chargeable at the average rate of tax, calculated in accordance with the '>
  > # end of ParaLine
  <ParaLine 
   <String `provisions of this rule, on the total income of the transitional previous year after excluding from '>
  > # end of ParaLine
  <ParaLine 
   <String `such total income the income relatable to any such period or periods which has already been '>
  > # end of ParaLine
  <ParaLine 
   <String `included or is includible in the total income of the previous year or previous years relevant to the '>
  > # end of ParaLine
  <ParaLine 
   <String `assessment year commencing on the 1st day of April, 1988.'>
   <ElementEnd `Para'>
