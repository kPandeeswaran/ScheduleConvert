 <ElementDef 
  <EDTag `Date'>
  <EDObject EDContainer>
  <EDValidHighestLevel No>
  <EDGeneralRule `<EMPTY\>'>
  <EDPgfFormat `'>
  <EDTextFormatRules 
   <ContextFormatRule 
    <If 
     <Context `'>
     <IsTextRange Yes>
     <FmtChangeListTag `Prospectivedate'>
    > # end of If
   > # end of ContextFormatRule
  > # end of EDTextFormatRules
  <EDPrefixRules 
   <ContextFormatRule 
    <If 
     <Context `Retrospective'>
     <ContextFormatRule 
      <If 
       <Context `* < Retrospective[Para = "Yes"] < Para'>
       <ElementPrefix `[\x12 wref <$attribute[Day:Retrospective]\>-<$attribute[Month:Retrospective]\>-<$attribute[Year:Retrospective]\>'>
      > # end of If
      <ElseIf 
       <Context `* < Retrospective < (Para | Title)'>
       <IsTextRange Yes>
       <ElementPrefix `wref <$attribute[Day:Retrospective]\>-<$attribute[Month:Retrospective]\>-<$attribute[Year:Retrospective]\>'>
       <FmtChangeList 
        <FPosition FSuperscript>
       > # end of FmtChangeList
      > # end of ElseIf
      <Else 
       <IsTextRange Yes>
       <ElementPrefix `wref <$attribute[Day:Retrospective]\>-<$attribute[Month:Retrospective]\>-<$attribute[Year:Retrospective]\>'>
      > # end of Else
     > # end of ContextFormatRule
    > # end of If
   > # end of ContextFormatRule
   <ContextFormatRule 
    <If 
     <Context `Prospective'>
     <ContextFormatRule 
      <If 
       <Context `* < Prospective[Para = "Yes"] < Para'>
       <ElementPrefix `[\x12 wef <$attribute[Day:Prospective]\>-<$attribute[Month:Prospective]\>-<$attribute[Year:Prospective]\>'>
      > # end of If
      <ElseIf 
       <Context `* < Prospective < (Para | Title)'>
       <IsTextRange Yes>
       <ElementPrefix `wef <$attribute[Day:Prospective]\>-<$attribute[Month:Prospective]\>-<$attribute[Year:Prospective]\>'>
       <FmtChangeList 
        <FPosition FSuperscript>
       > # end of FmtChangeList
      > # end of ElseIf
      <Else 
       <IsTextRange Yes>
       <ElementPrefix `wef <$attribute[Day:Prospective]\>-<$attribute[Month:Prospective]\>-<$attribute[Year:Prospective]\>'>
      > # end of Else
     > # end of ContextFormatRule
    > # end of If
   > # end of ContextFormatRule
  > # end of EDPrefixRules
  <EDSuffixRules 
   <ContextFormatRule 
    <If 
     <Context `* < Retrospective[Para = "Yes"] < Para'>
     <ElementSuffix `\x12 ]'>
    > # end of If
    <ElseIf 
     <Context `* < Prospective[Para = "Yes"] < Para'>
     <ElementSuffix `\x12 '>
    > # end of ElseIf
    <Else 
    > # end of Else
   > # end of ContextFormatRule
  > # end of EDSuffixRules
  <EDStartElementRules 
  >
  <EDEndElementRules 
  >
  <EDComments `'>
