    <FLocked No>
   > # end of Font
   <Char Tab>
   <String `From 1-4-1998 : Finance Act, 1997 : '>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Title'>
   <ElementBegin 
    <Unique 1405525>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `In the above clause (a) of r. 6 of Part A to Schedule IV the '>
  > # end of ParaLine
  <ParaLine 
   <String `word “twelve” was substituted for the word “ten” with effect from April 1, 1998 (i.e., for the assess'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `ment year 1998-99 and subsequent years) to provide that contributions by the employer of up to '>
  > # end of ParaLine
  <ParaLine 
   <String `twelve per cent. of the employee’s salary, to the credit of the employee participating in a recognised '>
  > # end of ParaLine
  <ParaLine 
   <String `provident fund will be exempt from tax in the employee’s hands.'>
   <ElementEnd `Para'>
   <ElementEnd `Notes'>
   <Marker 
    <MType 10>
    <MTypeName `Conditional Text'>
    <MText `=623679'>
    <MCurrPage `HIDDEN'>
    <Unique 1405529>
   > # end of Marker
