    <FLocked No>
   > # end of Font
   <String `2. Special provisions in a case where the transitional previous year is longer than twelve months.'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Emphasis'>
   <String `—In a '>
  > # end of ParaLine
  <ParaLine 
   <String `case where the transitional previous year is longer than twelve months, the provisions of this Act and '>
  > # end of ParaLine
  <ParaLine 
   <String `the Finance Act of the relevant year shall apply subject to the modifications specified in rules 3, 4, 5 '>
  > # end of ParaLine
  <ParaLine 
   <String `and 6 of this Schedule.'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
