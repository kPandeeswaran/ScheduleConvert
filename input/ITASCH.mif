  <ParaLine 
   <String `tinue to be 50 per cent. in the case of fire insurance or miscellaneous insurance not covered '>
  > # end of ParaLine
  <ParaLine 
   <String `by clause (a) of rule 6E : [2002] 256 ITR (St.) 1.'>
