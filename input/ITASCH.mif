   > # end of ElementBegin
   <Font 
    <FTag `'>
    <FLocked No>
    <FSeparation 4>
    <FColor `Blue'>
   > # end of Font
   <String ` Sub-rule (3) of rule 68A which provides for the payment by the Assessing Officer of the excess by '>
  > # end of ParaLine
  <ParaLine 
   <String `which the price of the property agreed upon under sub-rule (1) of the said rule between the Assessing Officer and the '>
  > # end of ParaLine
  <ParaLine 
   <String `defaulter exceeds the amount due to the defaulter within a period of three months from the date of delivery of posses'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `sion of the '>
   <Char DiscHyphen>
   <String `property to the Assessing Officer, with simple interest at the rate of six per cent. per annum to the defaulter '>
  > # end of ParaLine
  <ParaLine 
   <String `on such excess amount, for the period commencing on expiry of three months from the date of delivery of possession '>
  > # end of ParaLine
  <ParaLine 
   <String `of the property and ending with the date of payment of the amount that was remaining unpaid, was amended by substi'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `tution for the words “six per cent. per annum”, of the words “one-half per cent. for every month or part of a month” so as '>
  > # end of ParaLine
  <ParaLine 
   <String `to provide that interest shall be paid at the rate of one-half per cent. for every month or part of a month instead of six '>
  > # end of ParaLine
  <ParaLine 
   <String `per cent. per annum. This amendment took effect from April 1, 2008.'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Para'>
   <ElementEnd `Notes'>
   <Marker 
    <MType 10>
    <MTypeName `Conditional Text'>
    <MText `=428090'>
    <MCurrPage `HIDDEN'>
    <Unique 4648180>
   > # end of Marker
