    <FLocked No>
   > # end of Font
   <Char Tab>
   <String `From 1-4-2000 : Omission of transitory provisions :'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Title'>
   <ElementBegin 
    <Unique 1417355>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String ` Since the transitory provisions contained in '>
  > # end of ParaLine
  <ParaLine 
   <String `section 3 introduced in 1987 were applicable only for a limited period and these provisions were sub'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `stituted by a new section 3 by the Finance Act, 1999, with effect from April 1, 2000 (i.e., for the '>
  > # end of ParaLine
  <ParaLine 
   <String `assessment year 2000-2001 and subsequent years) omitting the transitory provisions and defining '>
  > # end of ParaLine
  <ParaLine 
   <String `“previous year” as a uniform period of the financial year immediately preceding the assessment year, '>
  > # end of ParaLine
  <ParaLine 
   <String `the Tenth Schedule was omitted with effect from the same date. The omitted Schedule read as fol'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `lows :'>
  > # end of ParaLine
 > # end of Para
