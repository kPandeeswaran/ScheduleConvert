   > # end of ElementBegin
   <Font 
    <FTag `Emphasis'>
    <FLocked No>
   > # end of Font
   <String `5. Modification in respect of depreciation allowance.'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Emphasis'>
   <String `—Where the assessee’s income under the head '>
  > # end of ParaLine
  <ParaLine 
   <String `“Profits and gains of business or profession” or under the head “Income from other sources” for a '>
  > # end of ParaLine
  <ParaLine 
   <String `period of thirteen months or more is included in his total income for the transitional previous year, '>
  > # end of ParaLine
  <ParaLine 
   <String `the allowance under clause (ii) of sub-section (1) of section 32 or, as the case may be, under clause (ii) '>
  > # end of ParaLine
  <ParaLine 
   <String `of section 57 in respect of depreciation on block of assets calculated in the manner stated in clause '>
  > # end of ParaLine
  <ParaLine 
   <String `(ii) of sub-section (1) of section 32, shall be increased by multiplying it by a fraction of which the '>
  > # end of ParaLine
  <ParaLine 
   <String `numerator is the number of months in the transitional previous year and the denominator is twelve :'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 1418190>
  <PgfTag `Para'>
  <ParaLine 
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementBegin 
    <Unique 1418189>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <Char Tab>
   <String `Provided that where more than one period in respect of income under the head “Profits and gains '>
  > # end of ParaLine
  <ParaLine 
   <String `of business or profession” or under the head “Income from other sources” are included in the transi'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `tional previous year under the first proviso or the third proviso to sub-section (2) of section 3, the '>
  > # end of ParaLine
  <ParaLine 
   <String `allowance in respect of depreciation on block of assets shall be calculated separately for each such '>
  > # end of ParaLine
  <ParaLine 
   <String `period included in the transitional previous year in the manner stated in clause (ii) of sub-section (1) '>
  > # end of ParaLine
  <ParaLine 
   <String `of section 32 and increased, where necessary, by multiplying it by a fraction of which the numerator '>
  > # end of ParaLine
  <ParaLine 
   <String `is the number of months in such period (after excluding the number of months relatable to the '>
  > # end of ParaLine
  <ParaLine 
   <String `period in relation to which depreciation on block of assets has been allowed or is allowable in the '>
  > # end of ParaLine
  <ParaLine 
   <String `previous year rele'>
   <Char DiscHyphen>
   <String `vant to the assessment year commencing on the 1st day of April, 1988) and the '>
  > # end of ParaLine
  <ParaLine 
   <String `denominator is twelve.'>
   <ElementEnd `Para'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
