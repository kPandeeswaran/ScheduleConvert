   > # end of Font
   <String `4. Modification in section 6.'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Emphasis'>
   <String `—Where the transitional previous year comprises a period of eighteen '>
  > # end of ParaLine
  <ParaLine 
   <String `months or more, then, sub-section (1) of section 6 shall be subject to the modification that references '>
  > # end of ParaLine
  <ParaLine 
   <String `therein to the periods of one hundred and eighty-two days, ninety days and sixty days shall be con'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `strued as references, respectively, to the periods of two hundred and seventy-three days, one hundred '>
  > # end of ParaLine
  <ParaLine 
   <String `and thirty-five days and ninety days.'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 1418186>
  <PgfTag `Para'>
  <ParaLine 
   <Font 
