   <Char Tab>
   <String `From 1-4-1973 : Finance Act, 1972 : '>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Title'>
   <ElementBegin 
    <Unique 1405551>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <ElementBegin 
    <Unique 1405554>
    <ETag `Emphasis'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <Font 
    <FTag `Emphasis'>
    <FLocked No>
   > # end of Font
   <String `Omission of Sixth Schedule and concession to priority industries :'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Emphasis'>
   <String ` '>
  > # end of ParaLine
  <ParaLine 
   <String `With effect from 1st April, 1973, the Sixth Schedule to the Income-tax Act was omitted. The omis'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `sion is consequential to the omission of section 80-I of the Income-tax Act and withdrawal of the con'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `cession for priority industries.'>
   <ElementEnd `Para'>
   <ElementEnd `Notes'>
   <Marker 
    <MType 10>
    <MTypeName `Conditional Text'>
    <MText `=480183'>
    <MCurrPage `HIDDEN'>
    <Unique 1405559>
   > # end of Marker
