           <ElementSuffix `: '>
          > # end of Else
         > # end of ContextFormatRule
        > # end of If
        <ElseIf 
         <Context `Proviso[Type = "Provided"]'>
         <IsTextRange Yes>
         <ElementSuffix `that '>
        > # end of ElseIf
       > # end of ContextFormatRule
      > # end of If
      <Else 
       <ElementSuffix ` '>
      > # end of Else
     > # end of ContextFormatRule
    > # end of ElseIf
    <Else 
    > # end of Else
