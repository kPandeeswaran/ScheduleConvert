   > # end of ElementBegin
   <Font 
    <FTag `Emphasis'>
    <FLocked No>
   > # end of Font
   <String `6. Modification in respect of rate of tax.'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <ElementEnd `Emphasis'>
   <String `—The tax chargeable on the total income of the transitional '>
  > # end of ParaLine
  <ParaLine 
   <String `previous year shall be calculated at the average rate of tax on the amount obtained by multiplying '>
  > # end of ParaLine
  <ParaLine 
   <String `such total income by a fraction of which the numerator is twelve and the denominator is the number '>
  > # end of ParaLine
  <ParaLine 
   <String `of months in the transitional previous year, as if the resultant amount were the total income :'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 1418204>
